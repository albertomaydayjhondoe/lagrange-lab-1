{
  "project_root": {
    "src": {
      "data": {
        "_comment": "LEGACY - Archivos locales (solo corpus .me activo)",
        "corpus": {
          "_status": "ACTIVO - Textos fuente",
          "_files": [
            "critica_socratica_lagrange.me",
            "miedo_al_miedo.me",
            "legitimidad_y_silencio.me"
          ]
        },
        "topology": {
          "_status": "DEPRECADO - Migrado a Supabase",
          "_legacy_files": ["nodes.json", "edges.json", "socratic_questions.json"],
          "_supabase_tables": ["topology_nodes", "topology_edges", "socratic_questions"]
        },
        "media": {
          "_status": "DEPRECADO - Migrado a Supabase",
          "_legacy_files": ["episodes.json"],
          "_supabase_tables": ["podcast_episodes"],
          "_storage_bucket": "podcast-episodes"
        }
      },
      "components": {
        "_comment": "INTERFAZ DE FRICCIÓN",
        "_files": [
          "LagrangeMap.tsx",
          "LagrangeNav.tsx",
          "AudioPlayer.tsx",
          "LabPromptEditor.tsx",
          "SocraticOracle.tsx",
          "SocraticDialogue.tsx"
        ],
        "admin": {
          "_comment": "MODO DIOS - Editores CRUD",
          "_files": [
            "NodeEditor.tsx",
            "EdgeEditor.tsx",
            "QuestionEditor.tsx",
            "EpisodeEditor.tsx",
            "AudioGenerator.tsx"
          ]
        }
      },
      "pages": {
        "_comment": "CAPAS PLATÓNICAS DE NAVEGACIÓN",
        "_files": [
          "Index.tsx",
          "Map.tsx",
          "Lab.tsx",
          "Admin.tsx",
          "Podcast.tsx",
          "Auth.tsx"
        ]
      },
      "utils": {
        "_comment": "LÓGICA DEL AGENTE - FULLSTACK",
        "_files": {
          "dataService.ts": "Fetch async desde Supabase (nodos, edges, questions, episodes)",
          "corpusSync.ts": "Validación y estadísticas (usa dataService)",
          "aiService.ts": "Conexión con Lovable AI para generación socrática",
          "narrativeMatrix.ts": "Motor de tensión narrativa",
          "interactionService.ts": "Tracking de interacciones (requiere auth)",
          "dataExport.ts": "Exportación de datos del sistema"
        }
      },
      "config": {
        "_comment": "CONFIGURACIÓN DEL ARQUITECTO",
        "_files": [
          "Lagrange_Architect_Prompt_v2.md",
          "Lagrange_IO_Director.js"
        ]
      }
    },
    "supabase": {
      "_comment": "BACKEND REAL - Lovable Cloud",
      "functions": {
        "_comment": "Edge Functions desplegadas automáticamente",
        "_files": [
          "socratic-oracle/index.ts",
          "elevenlabs-tts/index.ts"
        ]
      },
      "tables": {
        "topology_nodes": {
          "_rls": "SELECT: público | CUD: admin",
          "_fields": ["id", "label", "description", "x", "y", "weight", "color", "axis", "type", "corpus_refs", "question_count"]
        },
        "topology_edges": {
          "_rls": "SELECT: público | CUD: admin",
          "_fields": ["id", "source", "target", "tension", "label", "type"]
        },
        "socratic_questions": {
          "_rls": "SELECT: público | CUD: admin",
          "_fields": ["id", "eje", "nivel", "tension", "texto", "corpus_ref"]
        },
        "podcast_episodes": {
          "_rls": "SELECT: publicados o admin | CUD: admin",
          "_fields": ["id", "title", "description", "audio_url", "duration_seconds", "eje", "published", "published_at", "question_ids"]
        },
        "user_interactions": {
          "_rls": "INSERT: autenticado (propio user_id) | SELECT: autenticado (propias)",
          "_fields": ["id", "user_id", "session_id", "node_id", "interaction_type", "tension_level", "created_at"]
        },
        "profiles": {
          "_rls": "SELECT/UPDATE/INSERT: propio user_id",
          "_fields": ["id", "user_id", "display_name", "avatar_url", "role"]
        }
      },
      "storage": {
        "podcast-episodes": {
          "_public": true,
          "_purpose": "Audio files de episodios generados"
        }
      }
    }
  },
  "io_flows": {
    "public_read": {
      "_description": "Datos accesibles sin autenticación",
      "endpoints": [
        "GET topology_nodes",
        "GET topology_edges", 
        "GET socratic_questions",
        "GET podcast_episodes (published=true)",
        "INVOKE socratic-oracle"
      ]
    },
    "authenticated_write": {
      "_description": "Requiere usuario autenticado",
      "endpoints": [
        "INSERT user_interactions (user_id = auth.uid())",
        "CRUD profiles (user_id = auth.uid())"
      ]
    },
    "admin_mode": {
      "_description": "Modo Dios - Solo admin (is_admin_user())",
      "endpoints": [
        "CRUD topology_nodes",
        "CRUD topology_edges",
        "CRUD socratic_questions",
        "CRUD podcast_episodes",
        "INVOKE elevenlabs-tts"
      ]
    }
  },
  "metadata": {
    "version": "1.0.0",
    "sprint": "2 - Fullstack Migration",
    "architecture": "Lovable Cloud + Supabase",
    "mandamiento": "Neutralización del Miedo",
    "timestamp": "2024-12-28"
  }
}