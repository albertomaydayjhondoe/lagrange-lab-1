# ============================================================
# CONFIGURACIÓN DE VERCEL + SUPABASE
# Sistema de Tutorías Multi-Materia con IA y RAG
# ============================================================

# ============================================================
# SUPABASE (Requerido)
# ============================================================
# Obtén estos valores de: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=your-project-id

# ============================================================
# API KEY DE IA (Requerido para tutoring-oracle)
# ============================================================
# Esta variable se configura en Supabase Edge Functions, NO en Vercel
# Configurar en: https://app.supabase.com/project/_/functions/secrets
#
# Variables necesarias en Supabase Edge Functions:
# AI_API_KEY=sk-your-openai-api-key
# AI_GATEWAY_URL=https://api.openai.com/v1
# AI_CHAT_MODEL=gpt-4o-mini
# AI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# CONFIGURACIÓN OPCIONAL
# ============================================================

# ElevenLabs (TTS opcional)
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ============================================================
# NOTAS DE INSTALACIÓN
# ============================================================
#
# 1. CREAR PROYECTO EN SUPABASE:
#    - Ir a https://supabase.com/dashboard
#    - Crear nuevo proyecto
#    - Copiar URL y anon key
#
# 2. APLICAR MIGRACIONES:
#    - npx supabase db push
#    - O ejecutar manualmente el SQL en:
#      supabase/migrations/20260717000000_tutoring_multi_materia.sql
#
# 3. CONFIGURAR API KEY EN SUPABASE:
#    - Ir a https://app.supabase.com/project/_/functions/secrets
#    - Agregar AI_API_KEY con tu clave de OpenAI
#
# 4. DEPLOY EN VERCEL:
#    - Conectar repositorio
#    - Agregar variables de entorno VITE_*
#    - Deploy automático
#
# 5. DEPLOY EDGE FUNCTIONS:
#    - npx supabase functions deploy tutoring-oracle
#    - npx supabase functions deploy create-session
#    - npx supabase functions deploy book-session
#    - npx supabase functions deploy process-payment
#    - npx supabase functions deploy list-sessions
#    - npx supabase functions deploy cancel-booking
